{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deezy",
  "version": "0.2.2",
  "identifier": "com.pierr.deezy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Deezy",
        "width": 1100,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://e-cdns-images.dzcdn.net https://api.deezer.com https://cdns-images.dzcdn.net data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": {
        "cmd": "tauri",
        "args": ["signer", "sign", "$BUNDLEPATH"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/PierrunoYT/Deezy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0OENBRUMxQjNDQjgwQ0UKUldUT2dNdXp3YTZNZEhBZnZXemlHT0lFWkdXbjNOZENmUFlNL2FwZEt5NGV3dTRJV3prcW93K2MK"
    }
  }
}
