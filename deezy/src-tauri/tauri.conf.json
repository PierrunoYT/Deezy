{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deezy",
  "version": "0.2.17",
  "identifier": "com.pierr.deezy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Deezy",
        "width": 1100,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://*.dzcdn.net https://api.deezer.com data:; media-src 'self' https://*.dzcdn.net; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDNjRGRDcwOEE3NjJCRTgKUldUb0szYUtjUDFrUEVmZTlOYmRkR2VndHQ3bGZ4VjdObGorTmJQTi9QdFM0bnFlbURjQi8xdSsK",
      "endpoints": [
        "https://github.com/PierrunoYT/Deezy/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {}
  }
}
